    curl_multi_perform = thunk_curl_multi_perform
    curl_multi_poll = thunk_curl_multi_poll
    curl_multi_remove_handle = thunk_curl_multi_remove_handle
    curl_multi_setopt = thunk_curl_multi_setopt
    curl_multi_socket = thunk_curl_multi_socket
    curl_multi_socket_action = thunk_curl_multi_socket_action
    curl_multi_socket_all = thunk_curl_multi_socket_all
    curl_multi_strerror = thunk_curl_multi_strerror
    curl_multi_timeout = thunk_curl_multi_timeout
    curl_multi_wait = thunk_curl_multi_wait
    curl_multi_wakeup = thunk_curl_multi_wakeup

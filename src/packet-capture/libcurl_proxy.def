    curl_easy_reset = thunk_curl_easy_reset
    curl_easy_send = thunk_curl_easy_send
    curl_easy_strerror = thunk_curl_easy_strerror
    curl_easy_unescape = thunk_curl_easy_unescape
    curl_easy_upkeep = thunk_curl_easy_upkeep
    curl_escape = thunk_curl_escape
    curl_formadd = thunk_curl_formadd
    curl_formfree = thunk_curl_formfree
    curl_formget = thunk_curl_formget
    curl_free = thunk_curl_free
    curl_getdate = thunk_curl_getdate
    curl_getenv = thunk_curl_getenv
    curl_global_cleanup = thunk_curl_global_cleanup
    curl_global_init = proxy_curl_global_init
    curl_global_init_mem = proxy_curl_global_init_mem
    curl_global_sslset = thunk_curl_global_sslset
    curl_maprintf = thunk_curl_maprintf
    curl_mfprintf = thunk_curl_mfprintf
    curl_mime_addpart = thunk_curl_mime_addpart
    curl_mime_data = thunk_curl_mime_data
    curl_mime_data_cb = thunk_curl_mime_data_cb
    curl_mime_encoder = thunk_curl_mime_encoder
    curl_mime_filedata = thunk_curl_mime_filedata
    curl_mime_filename = thunk_curl_mime_filename
    curl_mime_free = thunk_curl_mime_free
    curl_mime_headers = thunk_curl_mime_headers
    curl_mime_init = thunk_curl_mime_init
    curl_mime_name = thunk_curl_mime_name
    curl_mime_subparts = thunk_curl_mime_subparts
    curl_mime_type = thunk_curl_mime_type
    curl_mprintf = thunk_curl_mprintf
    curl_msnprintf = thunk_curl_msnprintf
    curl_msprintf = thunk_curl_msprintf
    curl_multi_add_handle = thunk_curl_multi_add_handle

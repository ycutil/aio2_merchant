LIBRARY libcurl
EXPORTS
    ; Hooked functions - mapped to our proxy_ C implementations
    curl_easy_cleanup = proxy_curl_easy_cleanup
    curl_easy_init = proxy_curl_easy_init
    curl_easy_perform = proxy_curl_easy_perform
    curl_easy_setopt = proxy_curl_easy_setopt

    ; Pass-through functions - mapped to naked JMP thunks
    curl_easy_duphandle = thunk_curl_easy_duphandle
    curl_easy_escape = thunk_curl_easy_escape
    curl_easy_getinfo = thunk_curl_easy_getinfo
    curl_easy_option_by_id = thunk_curl_easy_option_by_id
    curl_easy_option_by_name = thunk_curl_easy_option_by_name
    curl_easy_option_next = thunk_curl_easy_option_next
    curl_easy_pause = thunk_curl_easy_pause
